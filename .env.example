# Agentic DevOps — environment configuration
# Copy to `.env` (project dir) or `~/.config/agentic-devops/.env` and fill in.
# Only the keys for the providers you actually use in your tiers are needed.

# --- Provider API keys (used by LiteLLM; name them per LiteLLM conventions) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# Ollama needs no key; set the tier's api_base in config.yaml instead.

# --- Database (Postgres + pgvector; required — sessions + knowledge base) ---
# In the bundled docker-compose stack this is set for you (points at the
# `postgres` service). Set it here to bind a managed instance (RDS/Aurora) or
# for native runs; run `agentic-devops db init` once to provision an existing DB.
# DATABASE_URL=postgresql://agentic:agentic@localhost:5432/agentic
# POSTGRES_PASSWORD=agentic     # compose only: password for the bundled postgres

# --- Admin control plane (optional; enables the /admin UI for hosts + knowledge) ---
# Generate the hash + secret with: agentic-devops admin set-password
# Until BOTH are set, the admin plane stays disabled (endpoints return 503); the
# assistant (chat) plane is unaffected.
# DEVY_ADMIN_PASSWORD_HASH=$2b$12$...      # bcrypt hash of the admin password
# DEVY_ADMIN_SECRET=...                     # HMAC signing secret (openssl rand -hex 32)
# DEVY_ENCRYPTION_KEY=...                   # Fernet key for per-host MCP tokens (Phase 9b)

# --- Optional scalar overrides (defaults shown) ---
# AGENTIC_DEVOPS_HOST=127.0.0.1
# AGENTIC_DEVOPS_PORT=8765
# AGENTIC_DEVOPS_DEFAULT_TIER=balanced
# AGENTIC_DEVOPS_MAX_ITERATIONS=12
# AGENTIC_DEVOPS_TRACING=jsonl            # jsonl | langsmith | none

# Point at a non-default operator config file (otherwise
# ~/.config/agentic-devops/config.yaml is used if present):
# AGENTIC_DEVOPS_CONFIG=/etc/agentic-devops/config.yaml

# Optional, only if AGENTIC_DEVOPS_TRACING=langsmith:
# LANGSMITH_API_KEY=...
